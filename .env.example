# ============================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
# ============================================================

# Your n8n ingestion webhook URL (from STEP2 workflow)
WEBHOOK_URL=https://your-n8n-instance/webhook/rag-ingest

# OpenAI API key (from platform.openai.com)
OPENAI_API_KEY=sk-...

# Supabase project URL (from Supabase → Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon/public key (from Supabase → Project Settings → API)
SUPABASE_ANON_KEY=your-anon-key-here

# Embedding model — must match what n8n uses (do not change)
EMBED_MODEL=text-embedding-3-small

# Number of top results to retrieve in benchmark
TOP_K=6
