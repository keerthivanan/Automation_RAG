# OpenAI API Key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Your LinkedIn login credentials
LINKEDIN_EMAIL=your-email@gmail.com
LINKEDIN_PASSWORD=your-password

# Your LinkedIn profile URL (exactly as it appears in your browser)
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/keerthi-vanan-s

# Describe yourself so Claude replies in your voice
BUSINESS_CONTEXT=I am Keerthivanan, a Gen AI Architect building AI automation systems for logistics and B2B SaaS. I share insights on AI, automation, and tech.

# How often to check for new comments (milliseconds). Default: 3 minutes
CHECK_INTERVAL_MS=180000
