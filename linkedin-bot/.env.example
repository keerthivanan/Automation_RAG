# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── LinkedIn session cookie (RECOMMENDED — works on laptop + VPS, no 2FA) ────
# How to get it:
#   1. Open LinkedIn in Chrome → F12 → Application → Cookies → www.linkedin.com
#   2. Find the cookie named "li_at" → copy its Value
#   3. Paste it below
LINKEDIN_LI_AT=your-li_at-cookie-value-here

# ── LinkedIn login (fallback if li_at is not set) ─────────────────────────────
LINKEDIN_EMAIL=your-email@gmail.com
LINKEDIN_PASSWORD=your-password

# ── Auto-reply bot settings (bot.js only) ─────────────────────────────────────
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile-slug
BUSINESS_CONTEXT=I am Keerthivanan, a Gen AI Architect building AI automation systems for logistics and B2B SaaS.
CHECK_INTERVAL_MS=180000
